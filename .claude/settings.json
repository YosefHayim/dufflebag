{
  "env": {
    "dufflebagContextWarnFraction": "0.18",
    "dufflebagContextBlockFraction": "0.2",
    "dufflebagAutorunDefaultCycleCount": "10",
    "dufflebagAutorunMaxCycleCount": "50",
    "dufflebagAutorunPollIntervalSeconds": "5",
    "dufflebagAutorunIdleThresholdSeconds": "8",
    "dufflebagSpeechVoice": "Samantha",
    "dufflebagSpeechWordsPerMinute": "230",
    "dufflebagDedupEnforcement": "deny"
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "node \"/Users/yosefhayimsabag/Desktop/Code/dufflebag/.claude/dufflebag/hooks/contextGuard.js\""
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "node \"/Users/yosefhayimsabag/Desktop/Code/dufflebag/.claude/dufflebag/hooks/contextGuard.js\""
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"/Users/yosefhayimsabag/Desktop/Code/dufflebag/.claude/dufflebag/hooks/contextGuard.js\""
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"/Users/yosefhayimsabag/Desktop/Code/dufflebag/.claude/dufflebag/hooks/ctxWatchSpawn.js\""
          }
        ]
      }
    ]
  }
}
